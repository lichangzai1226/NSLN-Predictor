        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;mermaid\nflowchart TB\n    S[\&quot;研究队列：205例&lt;br/&gt;NSLN阳性49例（23.9%）&lt;br/&gt;NSLN阴性156例（76.1%）\&quot;]\n\n    S --&gt; A[\&quot;方案一：单次7:3随机分层\&quot;]\n    S --&gt; B[\&quot;方案二：分层5折交叉验证\&quot;]\n\n    A --&gt; A1[\&quot;训练集约144例&lt;br/&gt;阳性约34例｜阴性约110例\&quot;]\n    A --&gt; A2[\&quot;测试集约61例&lt;br/&gt;阳性约15例｜阴性约46例\&quot;]\n    A1 --&gt; A3[\&quot;仅进行一次随机划分\&quot;]\n    A2 --&gt; A3\n    A3 --&gt; A4[\&quot;主要局限&lt;br/&gt;测试集仅约15个阳性事件&lt;br/&gt;评价结果容易受随机种子影响&lt;br/&gt;AUC、校准及DCA不稳定\&quot;]\n\n    B --&gt; B1[\&quot;按结局比例分成5组&lt;br/&gt;每组约41例&lt;br/&gt;阳性约9～10例\&quot;]\n    B1 --&gt; B2[\&quot;每轮：4组构成外层训练集&lt;br/&gt;约164例，阳性约39～40例\&quot;]\n    B1 --&gt; B3[\&quot;每轮：1组作为外层测试集&lt;br/&gt;约41例，阳性约9～10例\&quot;]\n    B2 --&gt; B4[\&quot;轮换5次\&quot;]\n    B3 --&gt; B4\n    B4 --&gt; B5[\&quot;每位患者获得一次&lt;br/&gt;未参与模型训练的测试预测\&quot;]\n    B5 --&gt; B6[\&quot;汇总205例OOF预测&lt;br/&gt;评价时包含全部49个阳性事件\&quot;]\n\n    A4 --&gt; C[\&quot;结论\&quot;]\n    B6 --&gt; C\n    C --&gt; D[\&quot;205例、49个阳性事件：&lt;br/&gt;分层5折比单次7:3更充分利用有限样本&lt;br/&gt;并降低一次随机划分带来的不稳定性\&quot;]\n\n    classDef cohort fill:#EAF3F8,stroke:#17466A,color:#102A3B,stroke-width:2px;\n    classDef split fill:#FDEEEE,stroke:#B84A4A,color:#562020,stroke-width:1.5px;\n    classDef fold fill:#EAF7EF,stroke:#31845C,color:#173F2B,stroke-width:1.5px;\n    classDef conclusion fill:#17466A,stroke:#17466A,color:#FFFFFF,stroke-width:2px;\n\n    class S cohort;\n    class A,A1,A2,A3,A4 split;\n    class B,B1,B2,B3,B4,B5,B6 fold;\n    class C,D conclusion;&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="Tq8BJLhfO_roktYwcT6i-1">
