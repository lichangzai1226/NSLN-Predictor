 left;&quot;&gt;&lt;font face=&quot;Times New Roman&quot;&gt;•&lt;span style=&quot;&quot;&gt;&amp;nbsp;&lt;/span&gt;Contrast-enhanced breast MRI images cannot be acquired&lt;span style=&quot;&quot;&gt;（n=250）&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
